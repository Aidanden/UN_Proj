generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}


model Student {
 id String @id @default(uuid()) //Primary Key   "c1a2b3d4-5678-90ab-cdef-1234567890ab"
 studentId String @unique
 firstName String
 lastName String
 email String 
 phone String @unique
 address String?
 dateOfBirth DateTime
 gender Gender
 status StudentStatus
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 departmentId String
 address2 String?
 city String?
 state String?
 country String?


 department Department @relation(fields: [departmentId], references: [id])
 enrollments Enrollment[]
}

model Department {
 id String @id @default(uuid()) //Primary Key   "c1a2b3d4-5678-90ab-cdef-1234567890ab"
 name String @unique
 code String @unique
 description String?
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt

  students Student[]
  instructors Instructor[]
  courses Course[]

}

model Instructor {
id String @id @default(uuid()) //Primary Key   "c1a2b3d4-5678-90ab-cdef-1234567890ab"
employeeId String @unique
firstName String
lastName String
email String @unique
phone String @unique
address String?
dateOfBirth DateTime
gender Gender
departmentId String
hireDate DateTime
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt

department Department @relation(fields: [departmentId], references: [id])
courses Course[]

}

model Course {
    id String @id @default(uuid()) //Primary Key   "c1a2b3d4-5678-90ab-cdef-1234567890ab"
    courseId String @unique
    name String
    description String?
    credits Int
    departmentId String
    instructorId String
    capacity Int @default(10)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt



    department Department @relation(fields: [departmentId], references: [id])
    instructor Instructor @relation(fields: [instructorId], references: [id])
    enrollments Enrollment[]
}
model Enrollment {
id String @id @default(uuid()) //Primary Key   "c1a2b3d4-5678-90ab-cdef-1234567890ab"
studentId String
courseId String
enrollmentDate DateTime
grade String?
gradePoint Float? 
attendance Int?
status EnrollmentStatus
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt
student Student @relation(fields: [studentId], references: [id])
course Course @relation(fields: [courseId], references: [id])


}


enum EnrollmentStatus {
  ENROLLED
  COMPLETED
  DROPPED
  FAILED
}

enum Gender {
    MALE
    FEMALE
}
enum StudentStatus {
    ACTIVE
    GRADUATED
    SUSPENDED
    WITHDRAWN
}

model User {
    id           String   @id @default(uuid())
    email        String   @unique
    passwordHash String
    name         String
    role         UserRole @default(ADMIN)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt
}

enum UserRole {
    ADMIN
}